{
  "name": "@obosbbl/grunnmuren-docs",
  "version": "0.0.1",
  "private": true,
  "description": "Grunnmuren documentation",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm build:props && pnpm build:colors && pnpm build:tsc && pnpm build:assets && pnpm sanity:extract && pnpm build:app",
    "build:app": "vite build",
    "build:assets": "mkdir -p public/resources/icons && cp -r node_modules/@obosbbl/grunnmuren-icons-svg/src/* public/resources/icons/",
    "build:colors": "node extract-colors.ts && oxfmt colors.ts",
    "build:props": "node extract-component-props.ts && oxfmt component-props.ts",
    "build:tsc": "tsc",
    "dev": "azure-env --env-filename=.env vite dev --port 3003",
    "dev:local-storybook": "VITE_STORYBOOK_BASE_URL=http://localhost:6006 pnpm dev",
    "sanity:extract": "sanity manifest extract --path public/studio/static",
    "sanity:schema:deploy": "sanity schema deploy",
    "sanity:typegen": "pnpm sanity:typegen:extract && pnpm sanity:typegen:generate",
    "sanity:typegen:extract": "sanity schema extract",
    "sanity:typegen:generate": "sanity typegen generate",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@code-obos/logger": "4.0.0-20260421111144",
    "@code-obos/sanity-auth": "1.4.4",
    "@obosbbl/grunnmuren-icons-react": "workspace:*",
    "@obosbbl/grunnmuren-icons-svg": "workspace:*",
    "@obosbbl/grunnmuren-react": "workspace:*",
    "@portabletext/react": "6.0.3",
    "@react-aria/utils": "3.34.0",
    "@sanity/asset-utils": "2.3.0",
    "@sanity/assist": "6.0.4",
    "@sanity/client": "7.22.0",
    "@sanity/code-input": "7.1.0",
    "@sanity/image-url": "2.1.1",
    "@sanity/preview-url-secret": "4.0.5",
    "@sanity/react-loader": "2.0.9",
    "@sanity/table": "2.0.1",
    "@sanity/vision": "5.22.0",
    "@sanity/visual-editing": "5.3.4",
    "@tanstack/nitro-v2-vite-plugin": "1.154.9",
    "@tanstack/react-router": "1.168.25",
    "@tanstack/react-start": "1.167.50",
    "@tanstack/react-store": "0.11.0",
    "@tanstack/store": "0.11.0",
    "@vitejs/plugin-react": "6.0.1",
    "cva": "1.0.0-beta.4",
    "groq": "5.22.0",
    "iron-session": "8.0.4",
    "pino-opentelemetry-transport": "3.0.0",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.3",
    "react-aria-components": "1.17.0",
    "react-dom": "19.2.3",
    "react-element-to-jsx-string": "17.0.1",
    "react-live": "4.1.8",
    "react-shiki": "0.9.1",
    "sanity": "5.22.0",
    "styled-components": "6.4.1",
    "use-debounce": "10.1.1"
  },
  "devDependencies": {
    "@code-obos/azure-env": "1.0.2",
    "@obosbbl/grunnmuren-tailwind": "workspace:*",
    "@react-aria/optimize-locales-plugin": "1.2.0",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-router-devtools": "1.166.13",
    "marked": "18.0.0",
    "react-docgen-typescript": "2.4.0",
    "tailwindcss": "catalog:",
    "vite": "8.0.8",
    "vite-tsconfig-paths": "6.1.1"
  }
}
