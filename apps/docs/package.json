{
  "name": "@obosbbl/grunnmuren-docs",
  "version": "0.0.1",
  "private": true,
  "description": "Grunnmuren documentation",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm build:props && pnpm build:colors && pnpm build:assets && pnpm sanity:extract && pnpm build:app",
    "build:app": "vite build",
    "build:assets": "mkdir -p public/resources/icons && cp -r node_modules/@obosbbl/grunnmuren-icons-svg/src/* public/resources/icons/",
    "build:colors": "node extract-colors.ts && oxfmt colors.ts",
    "build:props": "node extract-component-props.ts && oxfmt component-props.ts",
    "dev": "azure-env --env-filename=.env vite dev --port 3003",
    "dev:local-storybook": "VITE_STORYBOOK_BASE_URL=http://localhost:6006 pnpm dev",
    "sanity:extract": "sanity manifest extract --path public/studio/static",
    "sanity:schema:deploy": "sanity schema deploy",
    "sanity:typegen": "pnpm sanity:typegen:extract && pnpm sanity:typegen:generate",
    "sanity:typegen:extract": "sanity schema extract",
    "sanity:typegen:generate": "sanity typegen generate",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@code-obos/sanity-auth": "1.4.6",
    "@obosbbl/grunnmuren-icons-react": "workspace:*",
    "@obosbbl/grunnmuren-icons-svg": "workspace:*",
    "@obosbbl/grunnmuren-react": "workspace:*",
    "@portabletext/react": "6.2.0",
    "@react-aria/utils": "3.34.1",
    "@sanity/asset-utils": "2.3.0",
    "@sanity/assist": "6.1.15",
    "@sanity/client": "7.24.0",
    "@sanity/code-input": "7.3.0",
    "@sanity/image-url": "2.1.1",
    "@sanity/preview-url-secret": "4.1.0",
    "@sanity/table": "3.1.10",
    "@sanity/vision": "6.5.0",
    "@sanity/visual-editing": "5.5.1",
    "@tanstack/nitro-v2-vite-plugin": "1.155.0",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "@vitejs/plugin-react": "6.0.3",
    "cva": "1.0.0-beta.4",
    "groq": "6.5.0",
    "pino-opentelemetry-transport": "3.0.0",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.3",
    "react-aria-components": "1.18.0",
    "react-dom": "19.2.3",
    "react-element-to-jsx-string": "17.0.1",
    "react-live": "4.1.8",
    "react-shiki": "0.9.1",
    "sanity": "6.5.0",
    "styled-components": "6.4.3",
    "use-debounce": "10.1.1"
  },
  "devDependencies": {
    "@code-obos/azure-env": "1.0.3",
    "@obosbbl/grunnmuren-tailwind": "workspace:*",
    "@react-aria/optimize-locales-plugin": "2.0.0",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-router-devtools": "1.167.0",
    "marked": "18.0.5",
    "react-docgen-typescript": "2.4.0",
    "tailwindcss": "catalog:",
    "vite": "8.0.8",
    "vite-tsconfig-paths": "6.1.1"
  }
}
