{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["sanity.types.ts", "routeTree.gen.ts", "CHANGELOG.md", ".changeset/*.md"],
  "singleQuote": true,
  "sortPackageJson": {
    "sortScripts": true,
  },
  "sortImports": {},
  "sortTailwindcss": {
    "functions": ["cx", "cva"],
  },
}
