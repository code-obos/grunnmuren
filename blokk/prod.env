APP_KEY_VAULT_NAME=${APPLICATION_NAME}${CONTAINER_APP_KEY}prodkv # usually `<application-name><container-app-key><environment>kv`, but capped to maximum 24 characters
SHARED_KEY_VAULT_NAME=${APPLICATION_NAME}sharprodkv

APP_IDENTITY_ID=/subscriptions/${SUBSCRIPTION_ID}/resourcegroups/${RESOURCE_GROUP_NAME}/providers/Microsoft.ManagedIdentity/userAssignedIdentities/${IDENTITY_NAME}

OTEL_GATEWAY=https://blokk-otel.prod.blokk.obos.cloud
OTEL_KEY_VAULT_NAME=blokkotelsharedprodkv
